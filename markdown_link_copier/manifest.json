{
  "manifest_version": 3,
  "name": "Markdown Link Copier",
  "version": "1.0",
  "description": "表示中のページのURLとタイトルをMarkdown形式のリンクに変換し、クリップボードへコピーします。",
  "permissions": [
    "activeTab",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}

