{
  "manifest_version": 3,
  "name": "TVer Full Width Player",
  "version": "1.1",
  "description": "TVerの動画プレーヤーをブラウザ幅最大で表示します。",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_title": "最大化切り替え",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://tver.jp/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ]
}