{
  "manifest_version": 3,
  "name": "Amazon Markdown Copier",
  "version": "1.0",
  "description": "Amazonの商品ページから情報を取得し、Markdown形式のリンクを生成してクリップボードにコピーします。",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "Amazon Markdown Copier"
  }
}
